{
  "$schema": "./_schema.md#names",
  "note": "Weighted vocabulary for vessel names. The generator picks a theme allowed for the vessel's {power, role}, draws a stem, then applies the construction rule (navalPrefix + article) from powers.json. `themesByPower` maps power ids to the theme pools they may draw from. Naval and merchant draw from different pools. Keep stems period-plausible.",

  "articles": {
    "romance": { "usage": "French/Spanish/Portuguese", "masc": "Le", "fem": "La", "note": "Applied to French merchant names; naval ships often bare (Redoutable, Santísima Trinidad). Spanish/Portuguese frequently religious with no article." },
    "dutch":   { "usage": "Dutch", "prefix": "De", "note": "e.g. De Zeven Provinciën; merchant 'Vrouw'/'Jonge' constructions common." }
  },

