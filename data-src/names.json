  "romance": {
   "usage": "French/Spanish/Portuguese",
   "masc": "Le",
   "fem": "La",
   "note": "Applied to French merchant names; naval ships often bare (Redoutable, Santísima Trinidad). Spanish/Portuguese frequently religious with no article."
  },
  "dutch": {
   "usage": "Dutch",
   "prefix": "De",
   "note": "e.g. De Zeven Provinciën; merchant 'Vrouw'/'Jonge' constructions common."
  }
